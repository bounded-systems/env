{
  "name": "@bounded-systems/env",
  "version": "0.2.0",
  "description": "The one sanctioned reader of process.env, routing ambient config through capability imports",
  "bounded": {
    "tagline": "The one sanctioned reader of process.env, routing ambient config through capability imports",
    "kind": "door",
    "facet": "verb",
    "role": "capability-seam",
    "domain": "environment/config"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/env.git"
  },
  "homepage": "https://github.com/bounded-systems/env#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/env/issues"
  },
  "keywords": [
    "env",
    "process-env",
    "capability",
    "configuration",
    "ambient-authority",
    "seam"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
